# --- Database ---
DATABASE_URL="postgresql://claimsarathi:claimsarathi@localhost:5432/claimsarathi?schema=public"
POSTGRES_USER=claimsarathi
POSTGRES_PASSWORD=claimsarathi
POSTGRES_DB=claimsarathi

# --- API ---
API_PORT=4000
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173

# --- Storage ---
# "local" | "s3" (s3 adapter is stubbed for a later milestone)
STORAGE_DRIVER=local
STORAGE_LOCAL_ROOT=./uploads

# --- Notifications ---
# "console" is the default no-op provider for local dev; swap in Sparrow SMS later
SMS_PROVIDER=console
EMAIL_PROVIDER=console

# --- Web ---
VITE_API_BASE_URL=http://localhost:4000
